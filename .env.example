# ===== Copy to ".env" and fill =====

# Telegram bot token from @BotFather (e.g. 123456:ABC-DEF...)
TELEGRAM_BOT_TOKEN=

# Your channel username (with @) or numeric chat id. Bot must be an ADMIN of it.
TELEGRAM_CHANNEL=@your_channel

# Amazon Associates tag (e.g. yourname-21). Appended to product links so YOU
# earn the commission. Get it free at https://affiliate-program.amazon.in
AMAZON_ASSOC_TAG=

# Gemini free API key for writing catchy captions (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Actually post to Telegram? "false" = dry-run (prints only, safe testing).
DO_POST=false
